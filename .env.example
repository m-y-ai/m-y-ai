# Anthropic API key for Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-...

# Composio API key for Tool Router
COMPOSIO_API_KEY=ak_...

# WhatsApp
WHATSAPP_ALLOWED_DMS=+1234567890
WHATSAPP_ALLOWED_GROUPS=*

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_ALLOWED_DMS=*

# Signal
SIGNAL_PHONE_NUMBER=+1234567890
SIGNAL_ALLOWED_DMS=+1234567890

# iMessage (macOS only)
IMESSAGE_ALLOWED_DMS=+1234567890
IMESSAGE_ALLOWED_GROUPS=

# Web adapter (browser clients via SSE)
WEB_ENABLED=false
WEB_PORT=2701
WEB_API_KEY=                       # optional; leave blank to allow unauthenticated
WEB_ALLOWED_ORIGINS=*              # comma-separated origins or * for all
WEB_ALLOWED_DMS=*                  # comma-separated chatIds or * for all

# Mobile app adapter (React Native / native clients via SSE)
MOBILE_APP_ENABLED=false
MOBILE_APP_PORT=2702
MOBILE_APP_API_KEY=                # shared secret; all devices must send as X-Api-Key header
MOBILE_APP_ALLOWED_DEVICES=*       # comma-separated deviceIds or * for any authenticated device
MOBILE_APP_HEARTBEAT_MS=20000

# Web UI — URL that the browser uses to reach the gateway API (port 2700).
# The gateway HTTP server exposes /api/agents, /api/threads, and /api/threads/:id/messages (SSE).
# For local development: http://localhost:2700
# For production: https://your-domain.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:2700
